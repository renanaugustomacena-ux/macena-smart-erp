{
  "name": "@smarterp/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the SmartERP REST API (OpenAPI 3.1, ADR-035).",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "regen": "openapi-typescript-codegen --input ../../docs/openapi/v1.yaml --output src/generated --client fetch --useUnionTypes"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
