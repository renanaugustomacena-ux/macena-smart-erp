{
  "uid": "smarterp-api-performance",
  "title": "SmartERP — API Performance",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["smarterp", "api", "latency"],
  "timezone": "Europe/Rome",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency P50 / P95 / P99 (ms)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(smarterp_http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(smarterp_http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(smarterp_http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests per path",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (path) (rate(smarterp_http_requests_total[1m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Status-code distribution",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(smarterp_http_requests_total[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
