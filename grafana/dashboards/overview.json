{
  "uid": "smarterp-overview",
  "title": "SmartERP — Overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["smarterp", "overview"],
  "timezone": "Europe/Rome",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend availability",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"smarterp-backend\"}[5m]) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (RPS)",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (method) (rate(smarterp_http_requests_total[1m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate (status >= 400)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(smarterp_http_errors_total[1m])) / sum(rate(smarterp_http_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory usage (Node.js)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "smarterp_memory_bytes{area=\"heapUsed\"}",
          "legendFormat": "heapUsed",
          "refId": "A"
        },
        {
          "expr": "smarterp_memory_bytes{area=\"rss\"}",
          "legendFormat": "rss",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        { "expr": "smarterp_uptime_seconds", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Business KPIs (invoices / orders)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(smarterp_invoices_total[5m]))",
          "legendFormat": "invoices/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(smarterp_sales_orders_total[5m]))",
          "legendFormat": "sales_orders/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(smarterp_inventory_movements_total[5m]))",
          "legendFormat": "stock_movements/s",
          "refId": "C"
        }
      ]
    }
  ]
}
