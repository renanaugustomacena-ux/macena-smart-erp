{
  "uid": "smarterp-resources",
  "title": "SmartERP — Resources & Queues",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["smarterp", "infra", "bullmq"],
  "timezone": "Europe/Rome",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod CPU usage",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"smarterp\"}[1m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pod memory usage",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"smarterp\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "BullMQ job throughput by queue",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (queue, outcome) (rate(smarterp_queue_jobs_total[5m]))",
          "legendFormat": "{{queue}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Postgres connections in use",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 4 },
      "targets": [
        { "expr": "pg_stat_activity_count{datname=\"smarterp\"}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Redis connected clients",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 4 },
      "targets": [
        { "expr": "redis_connected_clients", "refId": "A" }
      ]
    }
  ]
}
